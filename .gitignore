# =============================================================================
# ClaimShield AI — repository-wide ignore rules
# Subdirectory .gitignore files (backend/, frontend/) add scoped rules.
# =============================================================================

# --- Secrets & environment ---
.env
.env.local
.env.production
.env.staging
.env.*.local
*.env
backend/.env
frontend/.env.local
frontend/.env.production

# Allow committed environment templates (negate ignore above)
!**/.env.example
!**/.env.local.example

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
*.egg
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.cover
coverage.xml
*.log

# --- Node / Next.js ---
node_modules/
.next/
out/
.vercel/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo
next-env.d.ts

# --- Database & Docker ---
*.sqlite
*.sqlite3
*.db
postgres-data/
pgdata/
docker-volumes/
.docker/

# --- IDE & OS ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# --- Keys & certificates ---
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
service-account*.json
*credentials*.json
*secret*.json

# --- Misc ---
*.zip
*.tar.gz
*.bak
*.tmp
.cache/
tmp/
temp/

# --- Local demo / debug artifacts (repo root) ---
.demo*.json
.uvicorn*.log
.uvicorn*.err
