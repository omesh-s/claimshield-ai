# =============================================================================
# ClaimShield AI — frontend (Next.js)
# Root .gitignore also applies.
# =============================================================================

# --- Secrets & environment ---
.env
.env.local
.env.production
.env.staging
.env.*.local
.env.development.local
.env.test.local

# Allow committed environment templates
!.env.example
!.env.local.example

# --- Node / Next.js ---
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.next/
out/
.vercel/
/build
/coverage
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo
next-env.d.ts

# --- IDE & OS ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# --- Keys & certificates ---
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
service-account*.json
*credentials*.json
*secret*.json

# --- Misc ---
*.zip
*.tar.gz
*.bak
*.tmp
.cache/
tmp/
temp/
