# ClaimShield AI — Frontend environment (copy to .env.local)
# NEVER commit .env.local to source control.

# Backend API base URL (use 127.0.0.1 to avoid Windows IPv6 localhost issues)
BACKEND_URL=http://127.0.0.1:8001/api/v1

# Optional: must match ADMIN_API_KEY in backend/.env for Settings admin actions
# NEXT_PUBLIC_ADMIN_KEY=claimshield-admin-2024
