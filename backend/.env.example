# ClaimShield AI — Backend Environment Variables
# Copy to .env and fill in REAL values before running.
# NEVER commit .env to source control.

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=development

# ── Database (matches docker-compose defaults) ───────────────────────────────
DATABASE_URL=postgresql+asyncpg://claimshield:claimshield@localhost:5432/claimshield
DATABASE_URL_SYNC=postgresql+psycopg2://claimshield:claimshield@localhost:5432/claimshield

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Google AI ────────────────────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── LLM settings ─────────────────────────────────────────────────────────────
# Confirmed working model IDs (google-generativeai 0.7.2, v1beta API):
GEMINI_MODEL=models/gemini-2.5-flash
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_MODEL_FALLBACK=models/gemini-embedding-2
EMBEDDING_DIMENSIONS=3072
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=60

# ── Admin API key (protects /api/v1/admin/* endpoints) ───────────────────────
# Any static string works for the hackathon demo.
ADMIN_API_KEY=claimshield-admin-2024

# ── Demo / rate limiting ──────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
